{
  "installCommand": "npm install",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "YEARBOOK_MAX_PDF_BYTES": "31457280",
    "YEARBOOK_MAX_PAGE_IMAGE_BYTES": "2097152",
    "YEARBOOK_MAX_PAGES": "50"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
